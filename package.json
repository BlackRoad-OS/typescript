{
  "name": "@blackroad-os/typescript",
  "version": "0.1.0",
  "description": "🛣️ TypeScript utilities and tools for the BlackRoad OS ecosystem",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "blackroad",
    "typescript",
    "utilities",
    "tools"
  ],
  "author": "BlackRoad OS, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackRoad-OS/typescript.git"
  },
  "bugs": {
    "url": "https://github.com/BlackRoad-OS/typescript/issues"
  },
  "homepage": "https://github.com/BlackRoad-OS/typescript#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {},
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
